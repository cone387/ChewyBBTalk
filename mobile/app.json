{
  "expo": {
    "name": "ChewyBBTalk",
    "slug": "mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "bundleIdentifier": "com.chewy.bbtalk",
      "buildNumber": "1",
      "supportsTablet": true,
      "infoPlist": {
        "NSFaceIDUsageDescription": "使用 Face ID 解锁防窥模式",
        "NSMicrophoneUsageDescription": "长按新建按钮进行语音录入",
        "NSSpeechRecognitionUsageDescription": "将语音转换为文字"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "apiBaseUrl": "https://bbtalk.cone387.top"
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "使用 Face ID 解锁防窥模式"
        }
      ],
      "@react-native-voice/voice",
      "expo-audio",
      "expo-video"
    ]
  }
}
