# ================================
# ChewyBBTalk 环境配置
# ================================
# Docker 部署时：本文件统一管理前后端所有配置
# 本地开发时：后端用 start_backend.sh 加载此文件，前端用 frontend/.env

# ================================
# 后端配置
# ================================
DEBUG=false
SECRET_KEY=                              # 留空则自动生成并持久化
ALLOWED_HOSTS=*
DATABASE_URL=sqlite:////app/data/db/db.sqlite3
# DATABASE_URL=postgresql://user:pass@host:5432/chewybbtalk

# 管理员账号（首次启动时创建）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:4010
CORS_ORIGIN_ALLOW_ALL=false

# S3 存储（可选，不配则用本地存储）
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_STORAGE_BUCKET_NAME=
# AWS_S3_ENDPOINT_URL=
# AWS_S3_REGION_NAME=us-east-1

# ================================
# 前端配置（VITE_* 变量在 Docker 构建时烧入 JS）
# ================================
VITE_API_BASE_URL=                       # 留空使用相对路径（Nginx 代理）
VITE_PRIVACY_TIMEOUT_MINUTES=5
VITE_SHOW_PRIVACY_COUNTDOWN=true
VITE_SITE_NAME=ChewyBBTalk
# VITE_MEDIA_URL_PROTOCOL=https          # 生产环境强制 HTTPS

# ================================
# Docker / 部署配置
# ================================
DATA_DIR=./data
PORT=4010
